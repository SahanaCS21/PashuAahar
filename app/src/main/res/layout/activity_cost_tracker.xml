<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F8F2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ICON -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💰"
            android:textSize="64sp"
            android:layout_gravity="center"/>

        <!-- TITLE -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cost Tracker"
            android:textSize="40sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"/>

        <!-- SUBTITLE -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Track cattle feed expenses"
            android:textSize="18sp"
            android:textColor="#607D8B"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"/>

        <!-- INPUT CARD -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="24dp">

            <!-- Feed Name -->

            <EditText
                android:id="@+id/etFeedName"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:hint="Feed Name"
                android:textSize="18sp"
                android:padding="16dp"
                android:background="#EDF2ED"
                android:textColor="#000000"
                android:textColorHint="#607D8B"/>

            <!-- Quantity -->

            <EditText
                android:id="@+id/etQuantity"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="18dp"
                android:hint="Quantity (kg)"
                android:inputType="numberDecimal"
                android:textSize="18sp"
                android:padding="16dp"
                android:background="#EDF2ED"
                android:textColor="#000000"
                android:textColorHint="#607D8B"/>

            <!-- Cost -->

            <EditText
                android:id="@+id/etCost"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="18dp"
                android:hint="Cost per kg (₹)"
                android:inputType="numberDecimal"
                android:textSize="18sp"
                android:padding="16dp"
                android:background="#EDF2ED"
                android:textColor="#000000"
                android:textColorHint="#607D8B"/>

            <!-- BUTTON -->

            <Button
                android:id="@+id/btnCalculate"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Calculate Expense"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2E7D32"
                android:layout_marginTop="24dp"/>

        </LinearLayout>

        <!-- RESULT CARD -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="24dp"
            android:layout_marginTop="28dp">

            <TextView
                android:id="@+id/txtResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Expense summary will appear here"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>