<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F8F2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TITLE -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🩺 Veterinary Care"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="30dp" />

        <!-- DAILY HEALTH CARD -->

        <LinearLayout
            android:id="@+id/dailyHealthCard"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="24dp"
            android:elevation="6dp"
            android:layout_marginBottom="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💚"
                android:textSize="42sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily Health Tips"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Daily cattle care and health guidance"
                android:textSize="16sp"
                android:textColor="#E8F5E9"
                android:layout_marginTop="6dp" />

        </LinearLayout>

        <!-- VACCINATION CARD -->

        <LinearLayout
            android:id="@+id/vaccinationCard"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="24dp"
            android:elevation="6dp"
            android:layout_marginBottom="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💉"
                android:textSize="42sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vaccination Reminder"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Important vaccine schedules for cattle"
                android:textSize="16sp"
                android:textColor="#E8F5E9"
                android:layout_marginTop="6dp" />

        </LinearLayout>

        <!-- NUTRITION CARD -->

        <LinearLayout
            android:id="@+id/nutritionCard"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="24dp"
            android:elevation="6dp"
            android:layout_marginBottom="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌾"
                android:textSize="42sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nutrition Advice"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Balanced feed and nutrition guidance"
                android:textSize="16sp"
                android:textColor="#E8F5E9"
                android:layout_marginTop="6dp" />

        </LinearLayout>

        <!-- EMERGENCY CARD -->

        <LinearLayout
            android:id="@+id/emergencyCard"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="24dp"
            android:elevation="6dp"
            android:layout_marginBottom="30dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚨"
                android:textSize="42sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Emergency Symptoms"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Identify dangerous cattle health symptoms"
                android:textSize="16sp"
                android:textColor="#E8F5E9"
                android:layout_marginTop="6dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>